@model NoteEditorViewModel

@{
    ViewData["Title"] = Model.IsNew ? $"Create {Model.Name}" : Model.Name;
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css">
}

<section class="note-shell">
    <div class="note-heading">
        <div>
            <span class="eyebrow">/@Model.Name</span>
            <h1>@(Model.IsNew ? "Create Nix" : "Edit Nix")</h1>
        </div>
        <div class="heading-actions">
            @if (!Model.IsNew && User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Bookmarks" asp-action="Toggle" method="post">
                    <input name="noteName" type="hidden" value="@Model.Name" />
                    <input name="returnUrl" type="hidden" value="@Url.Action("Open", "Notes", new { name = Model.Name })" />
                    <button class="btn btn-outline-secondary" type="submit">@(Model.IsBookmarked ? "Bookmarked" : "Bookmark")</button>
                </form>
            }
            <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">New path</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success" role="status">@Model.StatusMessage</div>
    }

    <div class="editor-layout">
        <form asp-controller="Notes" asp-action="Save" asp-route-name="@Model.Name" method="post" class="note-form">
            <input asp-for="Name" type="hidden" />
            <input asp-for="IsNew" type="hidden" />
            <input asp-for="IsProtected" type="hidden" />
            <input id="imageInput" type="file" accept="image/*" multiple hidden />

            <div class="editor-frame">
                <textarea asp-for="Content" id="Content" rows="18"></textarea>
            </div>

            <div class="save-bar">
                <div class="tag-field">
                    <label asp-for="TagsText" class="form-label">Tags</label>
                    <input asp-for="TagsText" class="form-control" placeholder="school, todo, draft" autocomplete="off" />
                </div>
                <div class="expiry-field">
                    <label asp-for="ExpiresIn" class="form-label">Expires In</label>
                    <select asp-for="ExpiresIn" class="form-control">
                        @if (!Model.IsNew && Model.ExpiresAt.HasValue)
                        {
                            <option value="">Keep current</option>
                        }
                        <option value="0">Never</option>
                        <option value="3600">1 hour</option>
                        <option value="86400">1 day</option>
                        <option value="604800">7 days</option>
                    </select>
                </div>
                @if (Model.IsNew)
                {
                    <div class="password-field">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" type="password" autocomplete="new-password" placeholder="Optional" />
                    </div>
                }
                else if (Model.IsProtected && !Model.IsUnlocked)
                {
                    <div class="password-field">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" type="password" autocomplete="current-password" required />
                    </div>
                }
                <div id="saveStatus" class="save-status" role="status" aria-live="polite">Idle</div>
                <button class="btn btn-primary" type="submit">Save</button>
            </div>
        </form>

        @if (!Model.IsNew)
        {
            <aside class="nix-panel" aria-label="Nix details">
                <section class="panel-section">
                    <h2>Insights</h2>
                    <dl class="insight-list">
                        <div>
                            <dt>Views</dt>
                            <dd>@Model.ViewCount</dd>
                        </div>
                        <div>
                            <dt>Last opened</dt>
                            <dd>@(Model.LastAccessedAt?.ToLocalTime().ToString("g") ?? "Never")</dd>
                        </div>
                        <div>
                            <dt>Updated</dt>
                            <dd>@(Model.UpdatedAt?.ToLocalTime().ToString("g") ?? "-")</dd>
                        </div>
                        <div>
                            <dt>Expires</dt>
                            <dd>@(Model.ExpiresAt?.ToLocalTime().ToString("g") ?? "Never")</dd>
                        </div>
                    </dl>
                </section>

                <section class="panel-section">
                    <h2>Tags</h2>
                    @if (Model.Tags.Count > 0)
                    {
                        <div class="tag-list">
                            @foreach (var tag in Model.Tags)
                            {
                                <a asp-controller="Notes" asp-action="Tagged" asp-route-tagName="@tag">#@tag</a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty-panel">No tags yet.</p>
                    }
                </section>

                <section class="panel-section">
                    <h2>History</h2>
                    @if (Model.Versions.Count > 0)
                    {
                        <div class="history-list">
                            @foreach (var version in Model.Versions)
                            {
                                <form asp-controller="Notes" asp-action="Restore" asp-route-name="@Model.Name" asp-route-versionId="@version.Id" method="post" class="history-item">
                                    <span>@version.CreatedAt.ToLocalTime().ToString("g")</span>
                                    @if (Model.IsProtected && !Model.IsUnlocked)
                                    {
                                        <input name="password" class="form-control form-control-sm" type="password" placeholder="Password" required />
                                    }
                                    <button class="btn btn-sm btn-outline-secondary" type="submit">Restore</button>
                                </form>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="empty-panel">No previous versions yet.</p>
                    }
                </section>
            </aside>
        }
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/dompurify/dist/purify.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
    <script>
        const imageInput = document.getElementById("imageInput");
        const noteName = @Json.Serialize(Model.Name);
        const contentInput = document.getElementById("Content");
        const noteForm = document.querySelector(".note-form");
        const tagsInput = document.getElementById("TagsText");
        const passwordInput = document.getElementById("Password");
        const expiresInput = document.getElementById("ExpiresIn");
        const saveStatus = document.getElementById("saveStatus");
        const requestToken = noteForm.querySelector("input[name='__RequestVerificationToken']").value;
        const draftKey = `draft-${window.location.pathname}`;
        const savedDraft = localStorage.getItem(draftKey);

        if (savedDraft && !contentInput.value.trim()) {
            contentInput.value = savedDraft;
            saveStatus.innerText = "Draft restored";
        }

        const customImageButton = {
            name: "image",
            action: function () {
                imageInput.click();
            },
            className: "fa fa-picture-o",
            title: "Attach image"
        };

        const editor = new EasyMDE({
            element: contentInput,
            spellChecker: false,
            status: false,
            autofocus: true,
            lineWrapping: true,
            toolbar: [
                "bold", "italic", "heading", "|",
                "quote", "unordered-list", "ordered-list", "|",
                "link", customImageButton, "|",
                "preview", "side-by-side", "fullscreen", "|",
                "guide"
            ],
            sanitizerFunction: function (renderedHtml) {
                return DOMPurify.sanitize(renderedHtml, {
                    ADD_DATA_URI_TAGS: ["img"]
                });
            }
        });

        let autoSaveTimeout = null;
        let isAutoSaving = false;
        let pendingAutoSave = false;
        let lastAutoSaveBody = null;

        function setSaveStatus(message) {
            saveStatus.innerText = message;
        }

        function getExpiryValue() {
            if (!expiresInput || expiresInput.value === "") {
                return null;
            }

            const expiresIn = Number.parseInt(expiresInput.value, 10);
            return Number.isNaN(expiresIn) ? null : expiresIn;
        }

        function buildAutoSaveBody() {
            editor.codemirror.save();

            return JSON.stringify({
                content: contentInput.value,
                password: passwordInput ? passwordInput.value : null,
                tagsText: tagsInput ? tagsInput.value : null,
                expiresIn: getExpiryValue()
            });
        }

        function scheduleAutoSave(message) {
            clearTimeout(autoSaveTimeout);
            localStorage.setItem(draftKey, contentInput.value);
            setSaveStatus(message || "Typing...");

            autoSaveTimeout = setTimeout(function () {
                autoSave();
            }, 2000);
        }

        async function autoSave() {
            if (isAutoSaving) {
                pendingAutoSave = true;
                return;
            }

            const body = buildAutoSaveBody();
            if (body === lastAutoSaveBody) {
                setSaveStatus("Saved");
                return;
            }

            isAutoSaving = true;
            setSaveStatus("Saving...");

            try {
                const response = await fetch(`/${encodeURIComponent(noteName)}/save`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": requestToken
                    },
                    body
                });

                if (response.status === 401) {
                    setSaveStatus("Password needed");
                    return;
                }

                if (response.status === 410) {
                    setSaveStatus("Expired");
                    return;
                }

                if (!response.ok) {
                    throw new Error("Auto-save failed.");
                }

                lastAutoSaveBody = body;
                localStorage.removeItem(draftKey);
                setSaveStatus("Saved");
            }
            catch {
                setSaveStatus("Error saving");
            }
            finally {
                isAutoSaving = false;
                if (pendingAutoSave) {
                    pendingAutoSave = false;
                    scheduleAutoSave("Typing...");
                }
            }
        }

        function insertImageFile(file) {
            if (!file || !file.type.startsWith("image/")) {
                return;
            }

            const formData = new FormData();
            formData.append("__RequestVerificationToken", requestToken);
            formData.append("image", file);

            fetch(`/${encodeURIComponent(noteName)}/image`, {
                method: "POST",
                headers: {
                    "RequestVerificationToken": requestToken
                },
                body: formData
            })
                .then(response => {
                    if (!response.ok) {
                        throw new Error("Image upload failed.");
                    }
                    return response.json();
                })
                .then(result => {
                    const safeName = (file.name || "image").replace(/[^\w.-]+/g, "-");
                    const markdown = `![${safeName}](${result.url})`;
                    editor.codemirror.replaceSelection(`${markdown}\n`);
                    editor.codemirror.focus();
                    editor.codemirror.save();
                    scheduleAutoSave("Typing...");
                })
                .catch(() => {
                    window.alert("The image could not be attached.");
                });
        }

        function insertImageFiles(files) {
            Array.from(files)
                .filter(file => file.type.startsWith("image/"))
                .forEach(insertImageFile);
        }

        imageInput.addEventListener("change", function () {
            insertImageFiles(imageInput.files);
            imageInput.value = "";
        });

        editor.codemirror.on("paste", function (_, event) {
            const files = event.clipboardData?.files;
            if (files && Array.from(files).some(file => file.type.startsWith("image/"))) {
                event.preventDefault();
                insertImageFiles(files);
            }
        });

        editor.codemirror.on("drop", function (_, event) {
            const files = event.dataTransfer?.files;
            if (files && Array.from(files).some(file => file.type.startsWith("image/"))) {
                event.preventDefault();
                insertImageFiles(files);
            }
        });

        editor.codemirror.on("change", function () {
            editor.codemirror.save();
            scheduleAutoSave("Typing...");
        });

        if (tagsInput) {
            tagsInput.addEventListener("input", function () {
                scheduleAutoSave("Editing tags...");
            });
        }

        if (expiresInput) {
            expiresInput.addEventListener("change", function () {
                scheduleAutoSave("Updating expiry...");
            });
        }

        noteForm.addEventListener("submit", function () {
            editor.codemirror.save();
        });
    </script>
}
